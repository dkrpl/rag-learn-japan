# Runtime
ENVIRONMENT=local
PROJECT_NAME="RAG Learn Japan API"
VERSION="1.0.0"
LOG_LEVEL=INFO
ENABLE_API_DOCS=true
ENABLE_METRICS=true

# MySQL (utf8mb4 required)
DATABASE_URL=mysql+pymysql://root:@127.0.0.1:3306/nihongo_db
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT_SECONDS=30
DB_POOL_RECYCLE_SECONDS=1800

# Redis / Celery
REDIS_URL=redis://127.0.0.1:6379/0
READINESS_CHECK_REDIS=true

# Security — generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=CHANGE_THIS_TO_A_RANDOM_SECRET_WITH_AT_LEAST_32_CHARACTERS
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
PASSWORD_RESET_EXPIRE_MINUTES=30
LOGIN_RATE_LIMIT_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW_SECONDS=300

# Frontend/API boundary (JSON arrays)
CORS_ORIGINS=["http://localhost:3000"]
ALLOWED_HOSTS=["localhost","127.0.0.1","testserver"]
CORS_ALLOW_CREDENTIALS=true
MAX_REQUEST_BODY_BYTES=10485760

# Managed audio storage
AUDIO_STORAGE_PROVIDER=local
AUDIO_STORAGE_PATH=data/uploads/audio
AUDIO_PUBLIC_BASE_URL=http://127.0.0.1:8000
AUDIO_MAX_UPLOAD_BYTES=10485760
AUDIO_ALLOWED_MIME_TYPES=["audio/mpeg","audio/mp3","audio/wav","audio/x-wav","audio/ogg","audio/webm"]

# S3-compatible storage (Cloudflare R2, MinIO, AWS S3)
S3_BUCKET_NAME=
S3_ENDPOINT_URL=
S3_REGION=auto
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PRESIGNED_URL_EXPIRE_SECONDS=900

# AI generation — disabled unless explicitly enabled
AI_PROVIDER=disabled
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
AI_REQUEST_TIMEOUT_SECONDS=60
AI_MAX_RETRIES=3

# TTS: disabled | gtts (local only) | google_cloud (staging/production)
TTS_PROVIDER=disabled
GOOGLE_TTS_LANGUAGE_CODE=ja-JP
GOOGLE_TTS_VOICE_NAME=ja-JP-Neural2-B
